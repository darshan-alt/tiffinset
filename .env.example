# Copy to .env for local development. In production, secrets come from GCP Secret Manager.

NODE_ENV=development
PORT=3000

# Transport
ACTIVE_TRANSPORT=telegram
TELEGRAM_BOT_TOKEN=
WEBHOOK_VERIFY_TOKEN=

# AI
GEMINI_API_KEY=
WHISPER_API_KEY=
YOUTUBE_API_KEY=

# Data
DATABASE_URL=postgres://tiffinset_admin@localhost:5432/tiffinset
REDIS_URL=redis://localhost:6379

# Swiggy OAuth (currently mocked)
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=

# Optional bearer token for /metrics — leave blank to expose unauthenticated.
METRICS_TOKEN=

# GCP project containing the Secret Manager secrets (production only).
GOOGLE_CLOUD_PROJECT=tiffinset

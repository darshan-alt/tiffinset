{
  "name": "tiffinset",
  "version": "3.0.0",
  "description": "Voice-first kitchen management bot for Indian households",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.0.0",
    "express": "^4.18.0",
    "form-data": "^4.0.0",
    "ioredis": "^5.3.0",
    "node-cron": "^3.0.0",
    "node-fetch": "^3.3.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.56.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node"
  },
  "eslintConfig": {
    "extends": ["eslint:recommended"],
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
    }
  }
}
